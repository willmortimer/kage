# Local-only developer overrides (do not commit your real values).
#
# Copy to `.env.local` and fill in as needed.
#
# Used by `scripts/mise/build-mac.sh` (Xcode signing) and optional codesign helpers.

# Apple Team ID (10-char), used to request Xcode signing.
# KAGE_DEVELOPMENT_TEAM=ABCDE12345

# Optional bundle identifier override for the helper app.
# If you don't set this, the Xcode project default is used.
# KAGE_BUNDLE_IDENTIFIER=dev.yourname.kage.kagehelper

# Codesign identity used to sign the Rust binaries so the helper sees a TeamIdentifier.
# Example (Apple Development):
# KAGE_CODESIGN_IDENTITY="Apple Development: Your Name (ABCDE12345)"
#
# Tip: you can also use the SHA-1 hash shown by `security find-identity -v -p codesigning`
# to avoid name matching issues:
# KAGE_CODESIGN_IDENTITY=870CD9F64B1AA005D5CF61A040FAB3621AABFE1D

# Local dev bypass for Team-ID checks in the XPC daemon.
# NOTE: This does not affect launchd; use `launchctl setenv KAGE_LOCAL_DEV 1` for the LaunchAgent.
# KAGE_LOCAL_DEV=1

# Allow `xcodebuild` to create/fetch provisioning profiles when signing is enabled.
# Requires you to be signed into Xcode (and may require an Apple Developer Program membership).
# KAGE_XCODE_ALLOW_PROVISIONING_UPDATES=1

# Optional: override Xcode signing mode/identity (useful for release signing).
# Examples:
# KAGE_XCODE_CODE_SIGN_STYLE=Automatic
# KAGE_XCODE_CODE_SIGN_STYLE=Manual
# KAGE_XCODE_CODE_SIGN_IDENTITY="Apple Development"
# KAGE_XCODE_CODE_SIGN_IDENTITY="Developer ID Application"
#
# When CODE_SIGN_STYLE=Manual, you can also clear provisioning settings:
# KAGE_XCODE_PROVISIONING_PROFILE_SPECIFIER=
# KAGE_XCODE_PROVISIONING_PROFILE=

# Optional: include a timestamp when codesigning Rust binaries.
# Default is 0 (no timestamp) for local/dev; CI releases should set 1.
# KAGE_CODESIGN_TIMESTAMP=1
